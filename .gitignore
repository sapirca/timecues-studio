# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code
.claude/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# allin1 byproducts (stems + spectrograms)
demix/
spec/

# Release-tree derived features (regenerate via archive/release/scripts/prepare_features.py)
archive/release/features/mel-spectrogram/*.npy

# Tmp / cache files
.features_msaf_tmp.json
texput.log
.pytest_cache/
.cache/

# User-local dataset — runtime working tree (./data/) and a local-only
# backup copy (archive/data/). Neither is tracked: the backup is for
# disk-only convenience, not git history (committing ~500 MB of audio +
# annotations would bloat the private repo forever).
data/*
!data/.gitkeep
archive/data/

# Paper release zips (regenerated via archive/paper_release/README.md)
archive/paper_release/*.zip
archive/paper/release/*.zip

# LaTeX build artifacts (regenerated by pdflatex/bibtex)
archive/paper/*.aux
archive/paper/*.bbl
archive/paper/*.blg
archive/paper/*.log
archive/paper/*.out
archive/paper/*.fls
archive/paper/*.fdb_latexmk
archive/paper/*.synctex.gz

# Docker / local secrets — never commit these (use .env.example as template).
# GCP secrets live under archive/gcp/.gcloud.env after the 2026-05-26 move.
.env
.env.local
web-app/.env.local
archive/gcp/.gcloud.env
archive/gcp/.gcloud.env.arm64
