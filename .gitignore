# Soft-deleted custom detectors (moved here by the UI delete; runtime only).
tools/python/custom/.trash/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code
.claude/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
.vite/

# allin1 byproducts (stems + spectrograms)
demix/
spec/

# Release-tree derived features (regenerate via archive/release/scripts/prepare_features.py)
archive/release/features/mel-spectrogram/*.npy

# Tmp / cache files
.features_msaf_tmp.json
texput.log
.pytest_cache/
.cache/

# User-local dataset — runtime working tree (./data/) and a local-only
# backup copy (archive/data/). Neither is tracked: the backup is for
# disk-only convenience, not git history (committing ~500 MB of audio +
# annotations would bloat the private repo forever).
data/*
!data/.gitkeep
archive/data/

# Paper release zips (regenerated via archive/paper_release/README.md)
archive/paper_release/*.zip
archive/paper/release/*.zip

# LaTeX build artifacts (regenerated by pdflatex/bibtex)
archive/paper/*.aux
archive/paper/*.bbl
archive/paper/*.blg
archive/paper/*.log
archive/paper/*.out
archive/paper/*.fls
archive/paper/*.fdb_latexmk
archive/paper/*.synctex.gz

# Screencast artifacts — regenerable / destined for external hosting (YouTube,
# Cloudflare). Keep the recorder tooling under archive/videos/capture/ tracked,
# but not the heavy media or exploration scratch.
archive/videos/recordings/
archive/videos/capture/out/
archive/videos/capture/_vo/
archive/videos/capture/_voices/
archive/videos/capture/frames/
archive/videos/capture/sheet-*.jpg
archive/videos/capture/check-*.jpg
archive/videos/capture/ff*.jpg
archive/videos/capture/contact-sheet.jpg
archive/videos/capture/voice-samples/
archive/videos/capture/narration-test*.mp3
archive/videos/capture/_profile/

# YouTube OAuth secret + cached token + video-id map — NEVER commit.
archive/videos/*client_secret*.json
archive/videos/client_secret.json
archive/videos/.yt_token.pickle
archive/videos/ids.json

# Docker / local secrets — never commit these (use .env.example as template).
.env
.env.local
web-app/.env.local
# Local-only secret env files used by the export-ignored deploy tooling.
archive/**/*.env*
