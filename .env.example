# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
#   cp .env.example .env

# ── Optional ───────────────────────────────────────────────────────────────
# Path to your data directory on the host. This is where uploaded audio,
# annotations, and algorithm caches live. Defaults to ./data/ next to this
# file. Use an absolute path to point at a folder anywhere else on disk.
#
# Examples:
#   DATA_DIR=/Users/you/timecues-data
#   DATA_DIR=/mnt/datasets/ismir-songs
#DATA_DIR=./data

# Linux only: run containers as your host user so files written into ./data/
# are owned by you (not root). On macOS/Windows Docker Desktop handles this
# automatically — leave commented out.
#
# Discover values with:  echo "$(id -u):$(id -g)"
#HOST_UID=1000
#HOST_GID=1000

# Google OAuth 2.0 client ID for sign-in. docker-compose.yml ships a working
# default that points at the upstream project's OAuth app, so localhost sign-in
# works out of the box for fresh clones. Override here only if you want to
# point sign-in at your own OAuth client (created in Cloud Console:
# https://console.cloud.google.com/apis/credentials).
#
# If you create your own client, add http://localhost:5173 to its "Authorized
# JavaScript origins" — without it Google will reject the sign-in iframe.
#VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
