# Keep the build context tiny — these directories are either huge,
# user-specific, secrets, or get bind-mounted at runtime so they don't
# need to be copied into images at all.

# User data — bind-mounted at runtime, NOT baked into image.
# (Songs now live under data/songs/. Annotations under data/annotations/.)
data/

# data-default/ is intentionally NOT ignored — it ships in the image as the
# read-only seed dataset (CC0 audio + song-info) the web app falls back to
# when the user's data/ is empty.

# Public sub-trees that hold runtime artifacts. Stems are regenerated by the
# python sidecars; bind-mounted at runtime. Analysis now lives under data/.
web-app/public/stems/
# Misc audio that may have ended up under public/ during dev — defaults
# now live under data-default/songs/, never under public/.
web-app/public/**/*.wav
web-app/public/**/*.flac
web-app/public/**/*.mp3
web-app/public/**/*.m4a
web-app/public/**/*.npy

# Node / build artifacts
web-app/node_modules/
web-app/dist/
web-app/.vite/
archive/landing/node_modules/
archive/landing/dist/
archive/landing/.astro/

# Git, caches, IDE
.git/
.github/
.vscode/
.idea/
**/__pycache__/
**/*.pyc

# Non-OSS content consolidated under archive/, plus allin1 byproducts.
# Exception: archive/landing/ is the Astro project the landing.Dockerfile
# builds from, so it must reach the Docker build context.
archive/
!archive/landing/
demix/
spec/

# Logs / scratch
*.log
.DS_Store

# Secrets — never bake into images
.env
.env.local
web-app/.env.local
